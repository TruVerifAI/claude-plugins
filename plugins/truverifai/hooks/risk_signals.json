{
  "_comment": "SINGLE SOURCE OF TRUTH for the two-channel risk classifier (docs/MCP/Classifier/risk-trigger-classifier-design.md). Canonical: mcp_server/risk_signals.json; vendored byte-identical copy: plugin/hooks/risk_signals.json (synced by scripts/sync_risk_classifier.py, enforced by tests/test_classifier_sync.py). Edit signals/weights/thresholds HERE only.",
  "version": "2.0.0",
  "thresholds": { "trigger": 25, "borderline_low": 5 },
  "large_hunk_added_lines": 50,
  "signals": [
    { "name": "hardcoded_secret", "class": "trigger", "category": "hardcoded_secret", "weight": 100, "auto_trigger": true, "match": "added",
      "patterns": [
        "(sk|pk)_(live|test)_[A-Za-z0-9]{16,}",
        "gh[posu]_[A-Za-z0-9]{30,}",
        "sk-ant-[A-Za-z0-9_-]{20,}",
        "AKIA[0-9A-Z]{12,}",
        "-----BEGIN [A-Z ]*PRIVATE KEY-----",
        "(?i)(password|secret|api[_-]?key|access[_-]?token)\\s*[:=]\\s*[\"'][^\"'\\s]{12,}[\"']"
      ] },
    { "name": "auth_security", "class": "trigger", "category": "auth_security", "weight": 30, "match": "added",
      "patterns": [
        "(?i)\\b(password|passwd|secret|api[_-]?key|bearer|jwt|oauth|session(_id)?|login|logout|permission|privilege|\\brole\\b|require_admin|is_admin|authenticate|authoriz|access[_-]?token|refresh[_-]?token)\\b",
        "@require_admin",
        "@(PreAuthorize|Secured|RolesAllowed|PermitAll|DenyAll)",
        "(?i)\\b(check_password|has_secure_password|set_password|verify_password)\\b",
        "(?i)from\\s+(django\\.contrib\\.auth|flask_login)",
        "(?i)(require|import).*['\"](devise|passport|next-auth|express-jwt|warden|pundit|cancancan)['\"]"
      ] },
    { "name": "billing", "class": "trigger", "category": "billing", "weight": 30, "match": "added",
      "patterns": [
        "(?i)\\b(stripe|braintree|paypal|adyen|chargebee)\\b",
        "(?i)\\b(charge|refund|payout|invoice|subscription|checkout|price_id|line_item)\\b",
        "Stripe::",
        "(?i)(import|from|require).*['\"]?stripe"
      ] },
    { "name": "crypto", "class": "trigger", "category": "crypto", "weight": 30, "match": "added",
      "patterns": [
        "(?i)\\b(encrypt|decrypt|hmac|cipher|fernet|bcrypt|argon2|pbkdf2|scrypt|hashlib|secrets\\.token|os\\.urandom|private[_-]?key)\\b",
        "(?i)(import|from)\\s+(cryptography|nacl|pycryptodome)\\b",
        "(?i)\"crypto/",
        "import\\s+javax\\.crypto"
      ] },
    { "name": "migration_schema", "class": "trigger", "category": "migration_schema", "weight": 35, "match": "added",
      "patterns": [
        "(?i)\\b(create|alter|drop)\\s+table\\b",
        "(?i)\\badd\\s+column\\b|\\bdrop\\s+column\\b",
        "\\bdb\\.Column\\b|\\bmapped_column\\b",
        "\\bop\\.(create_table|drop_table|add_column|drop_column|alter_column|rename_column)\\b",
        "(?i)\\bCREATE\\s+INDEX\\b|\\bFOREIGN\\s+KEY\\b",
        "(?i)\\b(create_table|drop_table|add_column|remove_column|add_index|change_column)\\b"
      ] },
    { "name": "migration_path", "class": "trigger", "category": "migration_schema", "weight": 25, "match": "path",
      "patterns": [ "(^|/)(migrations?|alembic/versions|db/migrate|prisma/migrations)(/|$)", "(?i)(^|/)V\\d+__.*\\.sql$" ] },
    { "name": "dependency", "class": "trigger", "category": "dependency", "weight": 30, "match": "path",
      "patterns": [ "(^|/)(requirements[^/]*\\.txt|package\\.json|pnpm-lock\\.yaml|yarn\\.lock|go\\.mod|go\\.sum|Gemfile(\\.lock)?|pyproject\\.toml|poetry\\.lock|Cargo\\.(toml|lock)|composer\\.json)$" ] },
    { "name": "dangerous_exec", "class": "trigger", "category": "dangerous_exec", "weight": 30, "match": "added",
      "patterns": [ "\\beval\\s*\\(", "\\bexec\\s*\\(", "subprocess\\.(run|call|Popen|check_output)", "os\\.(system|popen)\\s*\\(", "child_process\\.(exec|spawn|execSync|spawnSync)", "Runtime\\.getRuntime\\(\\)\\.exec", "\\bos/exec\\b" ] },
    { "name": "deserialization_untrusted", "class": "trigger", "category": "deserialization", "weight": 30, "match": "added",
      "patterns": [ "pickle\\.loads?\\s*\\(", "(?i)yaml\\.(unsafe_)?load\\s*\\(", "Marshal\\.load", "ObjectInputStream|\\breadObject\\s*\\(", "\\bunserialize\\s*\\(" ] },
    { "name": "env_access", "class": "trigger", "category": "env_access", "weight": 20, "match": "added",
      "patterns": [ "os\\.environ(\\[|\\.get)", "process\\.env\\.", "System\\.getenv\\s*\\(", "\\bENV\\[", "\\bgetenv\\s*\\(" ] },
    { "name": "sql_injection_surface", "class": "trigger", "category": "sql_risk", "weight": 25, "match": "added",
      "patterns": [ "(?i)(execute|query|raw)\\s*\\(\\s*[f\"'].*(SELECT|INSERT|UPDATE|DELETE).*\\+", "(?i)\\bTRUNCATE\\b" ] },
    { "name": "iac_public_exposure", "class": "trigger", "category": "iac_exposure", "weight": 35, "match": "added",
      "patterns": [ "0\\.0\\.0\\.0/0", "(?i)\"?(Action|Principal)\"?\\s*[:=]\\s*\"\\*\"", "\"\\*:\\*\"", "(?i)acl\\s*=\\s*\"public-read", "(?i)privileged\\s*[:=]\\s*true", "(?i)runAsUser\\s*[:=]\\s*0\\b" ] },
    { "name": "secret_material_path", "class": "trigger", "category": "secret_material", "weight": 25, "match": "path",
      "patterns": [ "(?i)\\.env(\\.[\\w-]+)?$", "(?i)(^|/)\\.env(\\.|$)", "(?i)\\.(pem|key|p12|pfx|jks|keystore)$", "(?i)(^|/)(secrets?|credentials?|vault)(/|\\.|_)" ] },
    { "name": "removed_safety_control", "class": "trigger", "category": "removed_guard", "weight": 30, "match": "removed",
      "patterns": [
        "(?i)\\b(is_admin|require_admin|authenticate|authoriz|permission|check_password|verify_|has_perm|csrf|sanitiz|escape|validate|\\bassert\\b|bounds|clamp)\\b",
        "(?i)\\bif\\b.*\\b(auth|admin|permission|valid|allow|denied|forbidden)\\b"
      ] },
    { "name": "ffi_unsafe", "class": "primitive", "category": "ffi_unsafe", "weight": 8, "match": "added",
      "patterns": [ "\\bunsafe\\s*\\{", "\\bptr::", "\\b(memcpy|malloc|free|memmove|alloca)\\s*\\(", "(?i)\\bvolatile\\b", "(?i)(import|require).*ctypes", "import\\s+\"C\"", "\\bJNIEXPORT\\b" ] },
    { "name": "concurrency", "class": "primitive", "category": "concurrency", "weight": 8, "match": "added",
      "patterns": [ "\\b(threading\\.|ThreadPoolExecutor|asyncio\\.|multiprocessing\\.)", "\\b(Lock|Semaphore|Mutex|RwLock)\\s*\\(", "\\bgo\\s+func\\b|<-", "\\basync\\s+def\\b" ] },
    { "name": "reflection_dynamic", "class": "primitive", "category": "dynamic_code", "weight": 8, "match": "added",
      "patterns": [ "\\bgetattr\\s*\\(|\\bsetattr\\s*\\(", "\\b__import__\\s*\\(", "\\breflect\\.", "\\.getDeclaredMethod\\b|Class\\.forName" ] },
    { "name": "network_egress", "class": "primitive", "category": "network_egress", "weight": 8, "match": "added",
      "patterns": [ "\\bsocket\\.socket\\s*\\(", "\\.listen\\s*\\(|\\.bind\\s*\\(" ] },
    { "name": "swallowed_error", "class": "primitive", "category": "swallowed_error", "weight": 6, "match": "added",
      "patterns": [ "except\\s*:\\s*pass", "except\\s+\\w+\\s*:\\s*pass", "catch\\s*\\([^)]*\\)\\s*\\{\\s*\\}", "catch\\s*\\{\\s*\\}" ] },
    { "name": "structural_significance", "class": "significance", "category": "significance", "weight": 10, "match": "added",
      "patterns": [ "(?i)^\\s*(export\\s+)?(public|pub)\\b", "(?i)^\\s*(export\\s+)?(async\\s+)?(def|function|fn|func)\\s+\\w+", "(?i)^\\s*(export\\s+(default\\s+)?)(class|interface|const|type)\\b" ] },
    { "name": "api_route", "class": "domain", "category": "api_route", "weight": 15, "match": "added",
      "patterns": [ "@\\w*\\.?(app|bp|router|blueprint)\\.(route|get|post|put|delete|patch)", "@app\\.route|\\.add_url_rule\\(|\\bBlueprint\\(", "@(Get|Post|Put|Delete|Patch)Mapping" ] },
    { "name": "api_route_path", "class": "domain", "category": "api_route", "weight": 10, "match": "path",
      "patterns": [ "(?i)(^|/)(routes?|controllers?|handlers?|endpoints?)(/|$)", "(?i)(^|/)api/v\\d" ] },
    { "name": "iac_domain_path", "class": "domain", "category": "iac", "weight": 10, "match": "path",
      "patterns": [ "(?i)\\.(tf|tfvars)$", "(?i)(^|/)(Dockerfile|docker-compose\\.ya?ml)$", "(?i)(^|/)(k8s|kubernetes|helm|charts)/", "(?i)\\.(cfn|template)\\.ya?ml$" ] },
    { "name": "mobile_domain", "class": "domain", "category": "mobile", "weight": 12, "match": "added",
      "patterns": [ "addJavascriptInterface|WKScriptMessageHandler", "(?i)(keychain|keystore)\\b", "<uses-permission" ] },
    { "name": "mobile_domain_path", "class": "domain", "category": "mobile", "weight": 10, "match": "path",
      "patterns": [ "(?i)(^|/)(AndroidManifest\\.xml|Info\\.plist)$", "(?i)\\.entitlements$" ] },
    { "name": "ml_data_domain", "class": "domain", "category": "ml_data", "weight": 12, "match": "added",
      "patterns": [ "\\b(torch\\.load|joblib\\.load|pickle\\.load)\\b", "\\btrain_test_split\\b", "\\b(random_state|np\\.random\\.seed|set_seed|manual_seed)\\b" ] },
    { "name": "ml_data_path", "class": "domain", "category": "ml_data", "weight": 8, "match": "path",
      "patterns": [ "(?i)\\.(ipynb|csv|parquet)$", "(?i)(^|/)(data|datasets|models)/" ] }
  ],
  "suppressors": [
    { "name": "test_path", "weight": -20, "match": "path",
      "patterns": [ "(?i)(^|/)(tests?|spec|__tests__|__mocks__|fixtures?|testdata)(/|$|\\.|_)", "(?i)\\.(test|spec)\\.(js|ts|jsx|tsx|py|rb|go|java|kt|cs|cpp|rs)$", "(?i)_test\\.(go|py|rb|java|kt|cs)$", "(?i)(^|/)test_[^/]*\\.py$" ] },
    { "name": "generated_vendor_path", "weight": -25, "match": "path",
      "patterns": [ "(?i)(^|/)(vendor|node_modules|generated|\\.generated|dist|build|__pycache__)(/|$)", "(?i)\\.(pb\\.go|pb\\.py|generated\\.(ts|js|java|cs))$" ] },
    { "name": "lockfile_path", "weight": -40, "match": "path",
      "patterns": [ "(?i)(package-lock\\.json|yarn\\.lock|poetry\\.lock|Pipfile\\.lock|Gemfile\\.lock|go\\.sum|cargo\\.lock|composer\\.lock)$" ] },
    { "name": "assets_path", "weight": -35, "match": "path",
      "patterns": [ "(?i)\\.(png|jpg|jpeg|gif|svg|ico|woff2?|ttf|eot|mp4|mp3|wav|pdf)$", "(?i)(^|/)(assets|static/(images|fonts))(/|$)" ] }
  ]
}
